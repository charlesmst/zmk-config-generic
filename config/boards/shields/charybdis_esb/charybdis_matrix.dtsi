#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,physical-layout = &charybdis_physical_layout;
    };

    charybdis_physical_layout: charybdis_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
            /* Row 0 */
            = <&key_physical_attrs 100 100    0   20       0     0     0>
            , <&key_physical_attrs 100 100  100   10       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300   10       0     0     0>
            , <&key_physical_attrs 100 100  400   20       0     0     0>
            , <&key_physical_attrs 100 100  700   20       0     0     0>
            , <&key_physical_attrs 100 100  800   10       0     0     0>
            , <&key_physical_attrs 100 100  900    0       0     0     0>
            , <&key_physical_attrs 100 100 1000   10       0     0     0>
            , <&key_physical_attrs 100 100 1100   20       0     0     0>
            /* Row 1 */
            , <&key_physical_attrs 100 100    0  120       0     0     0>
            , <&key_physical_attrs 100 100  100  110       0     0     0>
            , <&key_physical_attrs 100 100  200  100       0     0     0>
            , <&key_physical_attrs 100 100  300  110       0     0     0>
            , <&key_physical_attrs 100 100  400  120       0     0     0>
            , <&key_physical_attrs 100 100  700  120       0     0     0>
            , <&key_physical_attrs 100 100  800  110       0     0     0>
            , <&key_physical_attrs 100 100  900  100       0     0     0>
            , <&key_physical_attrs 100 100 1000  110       0     0     0>
            , <&key_physical_attrs 100 100 1100  120       0     0     0>
            /* Row 2 */
            , <&key_physical_attrs 100 100    0  220       0     0     0>
            , <&key_physical_attrs 100 100  100  210       0     0     0>
            , <&key_physical_attrs 100 100  200  200       0     0     0>
            , <&key_physical_attrs 100 100  300  210       0     0     0>
            , <&key_physical_attrs 100 100  400  220       0     0     0>
            , <&key_physical_attrs 100 100  700  220       0     0     0>
            , <&key_physical_attrs 100 100  800  210       0     0     0>
            , <&key_physical_attrs 100 100  900  200       0     0     0>
            , <&key_physical_attrs 100 100 1000  210       0     0     0>
            , <&key_physical_attrs 100 100 1100  220       0     0     0>
            /* Row 3 thumbs: left RC(3,2) RC(3,3) RC(3,0) | right RC(3,5) RC(3,7) */
            , <&key_physical_attrs 100 100  250  330       0     0     0>
            , <&key_physical_attrs 100 100  360  340       0     0     0>
            , <&key_physical_attrs 100 100  470  350       0     0     0>
            , <&key_physical_attrs 100 100  640  350       0     0     0>
            , <&key_physical_attrs 100 100  750  340       0     0     0>
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)  RC(0,9) RC(0,8) RC(0,7) RC(0,6) RC(0,5)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)  RC(1,9) RC(1,8) RC(1,7) RC(1,6) RC(1,5)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)  RC(2,9) RC(2,8) RC(2,7) RC(2,6) RC(2,5)
                            RC(3,2) RC(3,3) RC(3,0)  RC(3,5)  RC(3,7)
        >;
    };
};
