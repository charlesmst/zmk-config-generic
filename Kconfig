menu "roBa Features"

config ROBA_DESKHOP_LAYER_SYNC
    bool "Sync layers from DeskHop output changes"
    depends on ZMK_HID_INDICATORS
    default y
    help
      Switch between two base layers whenever host HID indicator bits change.

if ROBA_DESKHOP_LAYER_SYNC

config ROBA_DESKHOP_LAYER_SYNC_LED_MASK
    hex "HID indicator mask used as sync signal"
    default 0x01
    help
      USB HID indicator bitmask used as DeskHop signal.
      0x01 corresponds to Num Lock.

config ROBA_DESKHOP_LAYER_WHEN_LED_ON
    int "Layer to select when sync indicator is ON"
    default 1

config ROBA_DESKHOP_LAYER_WHEN_LED_OFF
    int "Layer to select when sync indicator is OFF"
    default 0

config ROBA_DESKHOP_LAYER_SYNC_DEBUG_KEY
    bool "Type debug key on sync event"
    default n
    help
      Sends a key tap to the host whenever a HID indicator sync event is received.

config ROBA_DESKHOP_LAYER_SYNC_DEBUG_KEY_USAGE
    hex "Debug key HID usage id"
    default 0x1d
    help
      HID usage id for the debug key. 0x1d is KEYBOARD_Z.

endif

config ROBA_PERIPHERAL_BATTERY_LED
    bool "Peripheral battery low indicator LED"
    depends on ZMK_SPLIT_ROLE_CENTRAL && ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_FETCHING
    help
      Blink the red LED when a peripheral reports a low battery level.

if ROBA_PERIPHERAL_BATTERY_LED

config ROBA_PERIPHERAL_BATTERY_LED_THRESHOLD
    int "Battery percentage threshold for low indicator"
    default 20
    help
      Blink the LED when a peripheral's battery is at or below this percentage.

endif

config ROBA_PMW3610_PERIPHERAL_KEYMAP_COMPAT
    bool "PMW3610 split peripheral keymap compatibility"
    depends on ZMK_SPLIT && !ZMK_SPLIT_ROLE_CENTRAL
    default n
    help
      Let the PMW3610 driver link on split peripherals by returning the
      default layer for its layer-mode query. Split peripherals do not own
      ZMK keymap state, so layer-based PMW3610 modes cannot be evaluated
      there; the central still processes the shared keymap.

endmenu
