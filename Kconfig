menu "roBa Features"

config ROBA_DESKHOP_LAYER_SYNC
    bool "Sync layers from DeskHop output changes"
    depends on ZMK_HID_INDICATORS
    default y
    help
      Switch between two base layers whenever host HID indicator bits change.

if ROBA_DESKHOP_LAYER_SYNC

config ROBA_DESKHOP_LAYER_SYNC_LED_MASK
    hex "HID indicator mask used as sync signal"
    default 0x01
    help
      USB HID indicator bitmask used as DeskHop signal.
      0x01 corresponds to Num Lock.

config ROBA_DESKHOP_LAYER_WHEN_LED_ON
    int "Layer to select when sync indicator is ON"
    default 1

config ROBA_DESKHOP_LAYER_WHEN_LED_OFF
    int "Layer to select when sync indicator is OFF"
    default 0

config ROBA_DESKHOP_LAYER_SYNC_DEBUG_KEY
    bool "Type debug key on sync event"
    default n
    help
      Sends a key tap to the host whenever a HID indicator sync event is received.

config ROBA_DESKHOP_LAYER_SYNC_DEBUG_KEY_USAGE
    hex "Debug key HID usage id"
    default 0x1d
    help
      HID usage id for the debug key. 0x1d is KEYBOARD_Z.

endif

endmenu
