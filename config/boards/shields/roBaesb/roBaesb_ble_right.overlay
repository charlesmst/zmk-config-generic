#include "../roBa/roBa.dtsi"
#include "../roBa/roBa_R_trackball.dtsi"
#include "roBaesb_ble_addr.dtsi"
#include <input/processors/xyz.dtsi>
#include <input/processors/report_rate_limit.dtsi>
#include <behaviors/input_processor_sigmoid_accel.dtsi>


&default_transform {
    col-offset = <6>;
};

&kscan0 {
    col-gpios
        = <&xiao_d 10 GPIO_ACTIVE_HIGH>
        , <&xiao_d 9 GPIO_ACTIVE_HIGH>
        , <&xiao_d 8 GPIO_ACTIVE_HIGH>
        , <&xiao_d 7 GPIO_ACTIVE_HIGH>
        , <&gpio0 10 GPIO_ACTIVE_HIGH>
        ;
};

&trackball_listener {
    status = "okay";
    device = <&trackball>;
    input-processors = <&sigmoid_accel>, <&zip_ble_report_rate_limit 8>;

    scroll {
        layers = <10>;
        input-processors = <&zip_ble_report_rate_limit 8>, <&zip_xy_scaler 1 10>, <&zip_xy_transform (INPUT_TRANSFORM_Y_INVERT)>, <&zip_xy_to_scroll_mapper>, <&sigmoid_accel>;
    };

    snipe {
        layers = <11>;
        input-processors = <&zip_xy_scaler 1 3>;
    };
};

&sigmoid_accel {
    cpi = <2600>;
};

&trackball {
    compatible = "pixart,pmw3610";
    spi-max-frequency = <2000000>;
    cpi = <2600>;
    y-invert;
    force-awake;
    force-high-performance;
    /delete-property/ invert-y;
};
